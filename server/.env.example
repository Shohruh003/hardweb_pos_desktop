# Lokal server sozlamalari

# HTTP/Socket port
PORT=3000

# PostgreSQL ulanishi (TZ bo'yicha asosiy baza)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=hardweb_pos

# Dev rejimda jadvallarni avtomatik yaratish (production'da false)
DB_SYNCHRONIZE=true

# Dev rejimda boshlang'ich ma'lumotlarni (seed) yuklash
SEED_ON_START=true

# JWT
JWT_SECRET=almashtiring-ushbu-maxfiy-kalitni
JWT_EXPIRES_IN=12h

# Bulut sinxron (5-bosqich). Bulut serveri /api manzili va shu restoran API kaliti.
SYNC_ENABLED=false
CLOUD_URL=http://localhost:4000/api
CLOUD_API_KEY=demo-api-key
SYNC_INTERVAL_MS=15000
