# Bulut serveri sozlamalari
PORT=4000

# Bulut PostgreSQL (docker postgres_cloud — 5433 portda)
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=hardweb_cloud
DB_SYNCHRONIZE=true

# Direktor login uchun JWT
JWT_SECRET=bulut-maxfiy-kalit-almashtiring
JWT_EXPIRES_IN=12h

# Platforma administratori kaliti (yangi restoran/tenant qo'shish uchun)
PLATFORM_ADMIN_KEY=platforma-admin-kaliti-almashtiring

# Dev: demo tenant (restoran) avtomatik yaratish
SEED_DEMO_TENANT=true
